# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_NAME=mf_relational
POSTGRES_USER=mf_user
POSTGRES_PASSWORD=mf_password

# TimescaleDB Configuration
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_NAME=mf_timeseries
TIMESCALEDB_USER=mf_user
TIMESCALEDB_PASSWORD=mf_password

# FastAPI Configuration
DEBUG=true
APP_NAME="Nivesh MF Analytics"
API_PORT=8000
API_HOST=0.0.0.0

# Streamlit Configuration
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0
BACKEND_URL=http://localhost:8000

# Data Source Configuration
NAV_PROVIDER=mfapi
DATA_SYNC_INTERVAL=3600  # seconds

# Logging Configuration
LOG_LEVEL=INFO
